{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "TravelSegment": {
      "title": "Travel Segment",
      "description": "A record of a travel journey from one country to another.",
      "type": "object",
      "properties": {
        "departureCountry": {
          "type": "string",
          "description": "The country the user is leaving from."
        },
        "departureDate": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time of departure."
        },
        "arrivalCountry": {
          "type": "string",
          "description": "The country the user is arriving in."
        },
        "arrivalDate": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time of arrival."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this record."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the record was created."
        }
      },
      "required": ["departureCountry", "departureDate", "arrivalCountry", "arrivalDate", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/travelSegments/{segmentId}": {
      "schema": "TravelSegment",
      "description": "Collection of travel segments for all users."
    }
  }
}
